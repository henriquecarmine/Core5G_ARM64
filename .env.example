# Variáveis de DEPLOY (uso local pelo deploy.sh) — copie para .env e ajuste.
# Variáveis do docker-compose (imagens etc.) ficam em server/.env.example.

# Servidor ARM AWS (acesso SSH)
# Use o hostname do DDNS quando configurado; até lá, o IP público (dinâmico) da instância
AWS_SERVER_HOST=<seu-ddns-ou-ip>
AWS_SERVER_USER=ubuntu
AWS_SSH_KEY_PATH=./ssl/core5g_openran_arm64.pem

# DuckDNS (atualização de IP dinâmico, usado pelo infra/server-bootstrap.sh)
DUCKDNS_DOMAIN=<seu-subdominio>
DUCKDNS_TOKEN=<seu-token>

# Painel web (server/panel/), protegido via Caddy basic_auth + HTTPS.
# Admin: acesso total. Guest: só visualiza, não executa nenhum comando.
PANEL_USER=<usuario-admin>
PANEL_PASSWORD=<senha-admin>
PANEL_GUEST_USER=<usuario-guest>
PANEL_GUEST_PASSWORD=<senha-guest>
