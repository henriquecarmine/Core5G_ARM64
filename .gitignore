*.pyc

# Plugins SM do FlexRIC: artefatos de build, arquitetura-específicos.
# NÃO versionar (o repo carregava x86-64 e o sync-oai quebrava o RIC arm64).
# up_flexric.sh popula flexric-lib/ do build tree por arquitetura do host.
server/oai-cn-gnb-e2/flexric-lib/*.so

