# =============================================================================
# server/.env — variáveis do docker-compose.yml (Open5GS Containerizado)
# =============================================================================
# Copie este arquivo para server/.env antes de subir os containers.
# Normalmente você não precisa mudar nada aqui — os valores padrão funcionam
# em amd64 e arm64 (AWS Graviton / Apple Silicon / Raspberry Pi 4+).
#
# ATENÇÃO — compatibilidade ARM64:
#   gradiant/open5gs:2.7.6+ NÃO tem build arm64.
#   Últimas tags com manifest linux/arm64/v8 confirmado: 2.7.2, 2.7.1, 2.7.0.
#   Se rodar em x86_64 pode usar versões mais recentes.
# =============================================================================

# --- Imagens Open5GS ---------------------------------------------------------
OPEN5GS_IMAGE=gradiant/open5gs:2.7.2
WEBUI_IMAGE=gradiant/open5gs-webui:2.7.2

# --- Infraestrutura ----------------------------------------------------------
MONGODB_IMAGE=mongo:7.0

# --- RAN simulada (UERANSIM) -------------------------------------------------
UERANSIM_IMAGE=gradiant/ueransim:3.2.6

# --- Data Network (destino dos pacotes UE, servidor iperf3) ------------------
DN_IMAGE=alpine:latest
