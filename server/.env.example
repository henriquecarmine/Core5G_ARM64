# Variáveis de ambiente do docker-compose.yml (Open5GS Containerizado).
# Copie este arquivo para server/.env e ajuste conforme necessário.

# Imagem base do Open5GS (contém todos os serviços)
# 2.7.6 NÃO tem build arm64 (só amd64). Últimas tags com manifest arm64/v8: 2.7.2, 2.7.1, 2.7.0.
OPEN5GS_IMAGE=gradiant/open5gs:2.7.2

# Imagem do WebUI do Open5GS (mesma observação de arquitetura do OPEN5GS_IMAGE)
WEBUI_IMAGE=gradiant/open5gs-webui:2.7.2

# Imagem do MongoDB
MONGODB_IMAGE=mongo:7.0

# Imagem do UERANSIM
UERANSIM_IMAGE=gradiant/ueransim:3.2.6

# Imagem do Data Network
DN_IMAGE=alpine:latest
